# ─── CLOUDSHADOW Agent Config ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER share your token with anyone

# Your server token (get this from CLOUDSHADOW dashboard)
CLOUDSHADOW_TOKEN=your_server_token_here

# Backend URL
CLOUDSHADOW_BACKEND_URL=http://localhost:8080

# Metrics sending interval in seconds
CLOUDSHADOW_INTERVAL=20

# Log level: DEBUG, INFO, WARNING, ERROR
CLOUDSHADOW_LOG_LEVEL=INFO